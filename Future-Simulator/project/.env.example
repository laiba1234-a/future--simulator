VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Grok AI (xAI) — narratives for simulation results
# Local dev: set GROK_API_KEY (not VITE_) so Vite proxies /api/grok without exposing the key
GROK_API_KEY=your_api_key_here
# Optional: override model (default grok-3-mini)
# VITE_GROK_MODEL=grok-3-mini
# Production: deploy supabase/functions/grok-simulate, set GROK_API_KEY in Supabase secrets, then:
# VITE_GROK_USE_SUPABASE=true
# Or point to any HTTPS proxy: VITE_GROK_PROXY_URL=https://your-host/grok
